<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"

    app:cardCornerRadius="18dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:orientation="horizontal"
        android:padding="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <!-- Icon -->
        <ImageView
            android:id="@+id/imgIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_voucher"
            android:background="@drawable/bg_circle_vouchers"
            android:padding="10dp"
            android:scaleType="centerInside" />

        <!-- Content -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvCode"
                android:text="Mã: ABC123"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#2F80FF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvName"
                android:text="Tên voucher"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#222"
                android:layout_marginTop="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvDesc"
                android:text="Mô tả voucher"
                android:textSize="13sp"
                android:textColor="#666"
                android:layout_marginTop="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Type + Value -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvType"
                    android:text="Loại:"
                    android:textSize="13sp"
                    android:textColor="#888"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvValue"
                    android:text="10%"
                    android:textStyle="bold"
                    android:textColor="#2F80FF"
                    android:textSize="15sp"
                    android:layout_marginStart="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvExpire"
                android:text="HSD: 30.11.2026"
                android:textSize="12sp"
                android:textColor="#FF9800"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvStatus"
                android:text="Sắp hết hạn"
                android:textSize="12sp"
                android:textColor="#FF9800"
                android:background="@drawable/bg_status_orange"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginTop="4dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnUse"
            android:text="Dùng ngay"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_btn_blue_rounded"
            android:layout_width="90dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</androidx.cardview.widget.CardView>