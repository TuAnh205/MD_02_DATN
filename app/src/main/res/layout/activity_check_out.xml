<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TITLE -->
        <TextView
            android:text="Thanh toán"
            android:textColor="@color/black"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- ADDRESS -->
        <TextView
            android:text="Địa chỉ nhận hàng"
            android:textColor="#757575"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:id="@+id/addressCard"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:src="@android:drawable/ic_menu_mylocation"
                android:tint="#2F80FF"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvShipName"
                    android:text="Tên người nhận"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/tvShipPhone"
                    android:text="Số điện thoại"
                    android:textColor="#444"
                    android:layout_marginTop="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/tvShipAddress"
                    android:text="Địa chỉ chi tiết"
                    android:textColor="#444"
                    android:layout_marginTop="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnChangeAddress"
                android:text="Đổi"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_blue"
                android:layout_width="wrap_content"
                android:layout_height="36dp" />
        </LinearLayout>

        <!-- PAYMENT -->
        <TextView
            android:text="Phương thức thanh toán"
            android:textColor="#757575"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <RadioGroup
            android:id="@+id/paymentGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/payCOD"
                android:text="Thanh toán khi nhận hàng (COD)"
                android:textColor="@color/black"
                android:buttonTint="#2F80FF"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <RadioButton
                android:id="@+id/payCard"
                android:text="Thanh toán bằng thẻ"
                android:textColor="@color/black"
                android:buttonTint="#2F80FF"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </RadioGroup>

        <!-- PRODUCTS -->
        <TextView
            android:text="Sản phẩm"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginTop="8dp"/>

        <!-- VOUCHER -->
        <TextView
            android:text="Mã giảm giá"
            android:textColor="#757575"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:id="@+id/layoutVoucherSelect"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvVoucherTitle"
                android:text="Chọn voucher"
                android:textColor="#222"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvVoucherValue"
                android:text=""
                android:textColor="#2F80FF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <ImageView
                android:src="@drawable/ic_right_arrow"
                android:tint="#000000"
                android:layout_width="20dp"
                android:layout_height="20dp"/>
        </LinearLayout>

        <!-- PRICE -->
        <TextView
            android:id="@+id/tvSubtotal"
            android:text="Tạm tính: 0đ"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvTax"
            android:text="Thuế: 0đ"
            android:textColor="@color/black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvVoucher"
            android:text="Giảm giá: -0đ"
            android:textColor="#E53935"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvTotal"
            android:text="Tổng thanh toán: 0đ"
            android:textColor="#2F80FF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- BUTTON -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnOrder"
            android:text="Đặt hàng"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:background="@drawable/bg_btn_blue"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

    </LinearLayout>
</ScrollView>