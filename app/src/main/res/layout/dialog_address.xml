<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:padding="32dp">

    <!-- Recipient Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tên người nhận"
        android:textColor="#E5E7EB"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:boxBackgroundColor="@android:color/white"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxStrokeColor="#374151"
        app:hintTextColor="#9CA3AF">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Ví dụ: Nguyễn Văn A"
            android:textColor="#222222"
            android:textColorHint="#9CA3AF"
            android:inputType="text"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@android:color/white" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Phone Number -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Số điện thoại"
        android:textColor="#E5E7EB"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:boxBackgroundColor="@android:color/white"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxStrokeColor="#374151"
        app:hintTextColor="#9CA3AF">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Ví dụ: 0912 345 678"
            android:textColor="#222222"
            android:textColorHint="#9CA3AF"
            android:inputType="phone"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@android:color/white" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Address -->

    <!-- City Spinner -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tỉnh/Thành phố"
        android:textColor="#E5E7EB"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <Spinner
        android:id="@+id/spinnerCity"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:background="#FFFFFF"
        android:padding="6dp"
        android:textColor="#E5E7EB"
        android:textSize="14sp" />

    <!-- District Spinner -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quận/Huyện"
        android:textColor="#E5E7EB"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <Spinner
        android:id="@+id/spinnerDistrict"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:background="#FFFFFF"
        android:padding="6dp"
        android:textColor="#E5E7EB"
        android:textSize="14sp" />

    <!-- Ward Spinner -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Phường/Xã"
        android:textColor="#E5E7EB"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <Spinner
        android:id="@+id/spinnerWard"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp"
        android:background="#FFFFFF"
        android:padding="6dp"
        android:textColor="#E5E7EB"
        android:textSize="14sp" />

    <!-- Số nhà, tên đường -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Số nhà, tên đường"
        android:textColor="#E5E7EB"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp"
        app:boxBackgroundColor="@android:color/white"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxStrokeColor="#374151"
        app:hintTextColor="#9CA3AF">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etAddress"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Ví dụ: 123 Đường Lê Lợi"
            android:textColor="#222222"
            android:textColorHint="#9CA3AF"
            android:inputType="text"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@android:color/white" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Default Address Checkbox -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbDefault"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#3B82F6" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sử dụng làm địa chỉ mặc định"
            android:textColor="#D1D5DB"
            android:textSize="14sp"
            android:layout_marginStart="12dp" />

    </LinearLayout>

</LinearLayout>
