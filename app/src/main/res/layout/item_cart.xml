<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_margin="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    card_view:cardCornerRadius="12dp"
    card_view:cardElevation="4dp"
    android:background="@drawable/bg_card_border"
    card_view:cardBackgroundColor="#FFFFFF"
    card_view:cardUseCompatPadding="true">

    <RelativeLayout
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- checkbox -->

        <CheckBox
            android:id="@+id/cbItem"
            android:buttonTint="#2F80FF"
            android:layout_centerVertical="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- image -->

        <ImageView
            android:id="@+id/imgProduct"
            android:layout_toEndOf="@id/cbItem"
            android:layout_marginStart="10dp"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_image"/>

        <!-- info -->

        <LinearLayout
            android:orientation="vertical"
            android:layout_toEndOf="@id/imgProduct"
            android:layout_marginStart="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvName"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvPrice"
                android:textColor="#2F80FF"
                android:textSize="15sp"
                android:layout_marginTop="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvLineTotal"
                android:textColor="#000000"
                android:textSize="14sp"
                android:layout_marginTop="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- quantity -->

            <LinearLayout
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btnMinus"
                    android:text="-"
                    android:textColor="#000000"
                    android:background="@drawable/ic_minus"
                    android:layout_width="30dp"
                    android:layout_height="30dp"/>

                <TextView
                    android:id="@+id/tvQty"
                    android:text="1"
                    android:textColor="#020202"
                    android:gravity="center"

                    android:layout_width="30dp"
                    android:layout_height="30dp"/>

                <Button
                    android:id="@+id/btnPlus"
                    android:text="+"
                    android:textColor="#000000"
                    android:background="@drawable/ic_plus"
                    android:layout_width="30dp"
                    android:layout_height="30dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- remove -->

        <TextView
            android:id="@+id/tvRemove"
            android:text="✕"
            android:textSize="20sp"
            android:textColor="#FF5C5C"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </RelativeLayout>

</androidx.cardview.widget.CardView>


