<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_card">

    <ImageView
        android:id="@+id/imgShopProduct"
        android:layout_width="116dp"
        android:layout_height="116dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_image"
        android:background="@drawable/bg_card" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvShopProductName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#122046"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvShopProductStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_blue"
                android:text="Đang hiển thị"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvShopProductDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#7A8BB2"
            android:textSize="13sp"
            android:layout_marginTop="6dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvShopProductPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#2F80FF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/tvShopProductStock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#7A8BB2"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_edit"
                android:tint="#2F80FF" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_eye"
                android:tint="#7A8BB2" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_delete"
                android:tint="#FF4D4D" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
