<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:tint="#122046"
            android:contentDescription="Quay lại" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thêm sản phẩm mới"
            android:textColor="#122046"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- THÔNG TIN CƠ BẢN -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="THÔNG TIN CƠ BẢN"
                android:textColor="#7A8BB2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Tên sản phẩm -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tên sản phẩm"
                    android:textColor="#122046"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/edtProductName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_search"
                    android:hint="Ví dụ : iPhone 15 Pro MAX"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="#122046"
                    android:textColorHint="#7A8BB2"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Danh mục -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Danh mục"
                    android:textColor="#122046"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerCategory"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_search"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:entries="@array/product_categories" />
            </LinearLayout>

            <!-- Giá bán -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Giá bán"
                        android:textColor="#122046"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VND"
                        android:textColor="#7A8BB2"
                        android:textSize="13sp" />
                </LinearLayout>

                <EditText
                    android:id="@+id/edtPrice"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_search"
                    android:hint="0"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="number"
                    android:textColor="#122046"
                    android:textColorHint="#7A8BB2"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Tồn kho -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tồn kho"
                    android:textColor="#122046"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/edtStock"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_search"
                    android:hint="0"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="number"
                    android:textColor="#122046"
                    android:textColorHint="#7A8BB2"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E6EDF8"
                android:layout_marginBottom="20dp" />

            <!-- MÔ TẢ CHI TIẾT -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MÔ TẢ CHI TIẾT"
                android:textColor="#7A8BB2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Description -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <EditText
                    android:id="@+id/edtDescription"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_search"
                    android:hint="Nhập mô tả sản phẩm tại đây ...."
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:gravity="top"
                    android:textColor="#122046"
                    android:textColorHint="#7A8BB2"
                    android:textSize="14sp"
                    android:maxLines="5" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvCharCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/500"
                        android:textColor="#7A8BB2"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E6EDF8"
                android:layout_marginBottom="20dp" />

            <!-- Image URL Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Link ảnh URL"
                    android:textColor="#122046"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/edtImageUrl"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_search"
                    android:hint="https://example.com/image.jpg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="#122046"
                    android:textColorHint="#7A8BB2"
                    android:textSize="14sp"
                    android:inputType="text" />
            </LinearLayout>

            <!-- Images Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginBottom="24dp">

                <!-- Image 1 (Add Photo) -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp">

                    <ImageView
                        android:id="@+id/ivProductImage1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/bg_search"
                        android:scaleType="centerInside"
                        android:background="@drawable/bg_card" />

                    <Button
                        android:id="@+id/btnAddPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:text="+ Thêm ảnh"
                        android:textColor="#0A6ED8"
                        android:textSize="12sp" />
                </FrameLayout>

                <!-- Image 2 (Product Image) -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1">

                    <ImageView
                        android:id="@+id/ivProductImage2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_card" />

                    <ImageView
                        android:id="@+id/ivRemoveImage"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_close"
                        android:tint="#FF6B6B"
                        android:layout_gravity="top|end"
                        android:layout_margin="4dp"
                        android:visibility="gone"
                        android:contentDescription="Xóa ảnh" />
                </FrameLayout>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:elevation="8dp">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search"
            android:text="Hủy"
            android:textColor="#122046"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginEnd="12dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_blue"
            android:text="Lưu sản phẩm"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
