<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thông tin tài khoản"
        android:textSize="22sp"
        android:textColor="#122046"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quản lý thông tin và đăng xuất khỏi tài khoản" 
        android:textColor="#7A8BB2"
        android:textSize="14sp"
        android:layout_marginTop="8dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="#E5E7EB" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tên"
        android:textColor="#1F2937"
        android:textSize="12sp"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/tvUserName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Admin User"
        android:textColor="#111827"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="6dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Vai trò"
        android:textColor="#1F2937"
        android:textSize="12sp"
        android:layout_marginTop="18dp" />

    <TextView
        android:id="@+id/tvUserRole"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quản trị viên"
        android:textColor="#111827"
        android:textSize="16sp"
        android:layout_marginTop="6dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Email"
        android:textColor="#1F2937"
        android:textSize="12sp"
        android:layout_marginTop="18dp" />

    <TextView
        android:id="@+id/tvUserEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="admin@example.com"
        android:textColor="#111827"
        android:textSize="16sp"
        android:layout_marginTop="6dp" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="32dp"
        android:text="Đăng xuất"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:backgroundTint="#0A6ED8" />

</LinearLayout>
