<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="48dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_back"
                android:tint="?attr/colorOnBackground"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CORE-TECH"
                android:textColor="#1E88E5"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <!-- Icon -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="34dp"
            android:src="@drawable/reset1"
            android:layout_gravity="center"/>

        <!-- Title -->

        <!-- Desc -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="42dp"
            android:text="Reset Password"
            android:textColor="?attr/colorOnBackground"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_marginTop="8dp"
            android:text="Enter the email or phone number associated with your account and we’ll send an OTP to verify your identity."
            android:textColor="#9AA7B2"
            android:textSize="14sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Credentials -->
        <TextView
            android:layout_marginTop="42dp"
            android:text="CREDENTIALS"
            android:textStyle="bold"
            android:textColor="?attr/colorOnBackground"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/edt_email"
            android:hint="Enter email or phone"
            android:inputType="text"
            android:padding="16dp"
            android:textColor="?attr/colorOnBackground"
            android:textColorHint="#7F8C99"

            android:drawablePadding="12dp"/> 

        <TextView
            android:layout_marginTop="8dp"
            android:text="Format: name@domain.com or +1 234 567 8900"
            android:textColor="#7F8C99"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnReset"
            android:layout_marginTop="240dp"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Send OTP  >"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:background="@drawable/btn_login"/>

        <!-- Footer -->
        <TextView
            android:layout_marginTop="24dp"
            android:layout_gravity="center"
            android:text="Remembered your password?"
            android:textColor="#9AA7B2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvBackLogin"
            android:layout_gravity="center"
            android:text="Back to Login"
            android:textColor="#1E88E5"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>
