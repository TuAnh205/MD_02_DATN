<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0B1A2B"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- header -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal">

            <ImageView
                android:id="@+id/imgAvatar"
                android:src="@drawable/ic_user"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_circle_blue"
                android:padding="4dp"/>

            <ImageView
                android:id="@+id/imgEdit"
                android:src="@drawable/ic_edit"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_circle_blue"
                android:padding="4dp"/>
        </FrameLayout>

        <TextView
            android:id="@+id/tvName"
            android:text="Alex Johnson"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvEmail"
            android:text="alex.johnson@coretech.io"
            android:textColor="#AAAAAA"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- stats boxes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_height="wrap_content">
                <TextView
                    android:text="Đơn HÀNG"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/tvOrderCount"
                    android:text="24"
                    android:textColor="#2F80FF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_height="wrap_content">
                <TextView
                    android:text="YÊ THÍCH"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/tvWishlistCount"
                    android:text="12"
                    android:textColor="#2F80FF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- menu items -->
        <TextView
            android:text="TÀI KHOẢN"
            android:textColor="#AAAAAA"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- each row -->
            <LinearLayout
                android:id="@+id/rowOrders"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:src="@drawable/ic_cart"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>
                <TextView
                    android:text="Đơn hàng của tôi"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:src="@drawable/ic_right_arrow"
                    android:layout_width="16dp"
                    android:layout_height="16dp"/>
            </LinearLayout>

            <!-- other rows similar -->
            <LinearLayout
                android:id="@+id/rowAddress"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:src="@drawable/ic_location"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>
                <TextView
                    android:text="Địa chỉ giao hàng"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:src="@drawable/ic_right_arrow"
                    android:layout_width="16dp"
                    android:layout_height="16dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowPayment"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:src="@drawable/ic_payment"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>
                <TextView
                    android:text="Phương thức thanh toán"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:src="@drawable/ic_right_arrow"
                    android:layout_width="16dp"
                    android:layout_height="16dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowWishlist"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:src="@drawable/ic_heart"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>
                <TextView
                    android:text="Sản phẩm yêu thích"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:src="@drawable/ic_right_arrow"
                    android:layout_width="16dp"
                    android:layout_height="16dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- settings section -->
        <TextView
            android:text="CÀI ĐẶT"
            android:textColor="#AAAAAA"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/rowNotifications"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:src="@drawable/ic_notifications"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>
                <TextView
                    android:text="Thông báo"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:src="@drawable/ic_right_arrow"
                    android:layout_width="16dp"
                    android:layout_height="16dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowPrivacy"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:src="@drawable/ic_privacy"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>
                <TextView
                    android:text="Quyền riêng tư &amp; Bảo mật"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:src="@drawable/ic_right_arrow"
                    android:layout_width="16dp"
                    android:layout_height="16dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowLanguage"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:src="@drawable/ic_language"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>
                <TextView
                    android:text="Ngôn ngữ"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/tvLanguage"
                    android:text="Tiếng Việt"
                    android:textColor="#2F80FF"
                    android:layout_marginEnd="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:src="@drawable/ic_right_arrow"
                    android:layout_width="16dp"
                    android:layout_height="16dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowDarkMode"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:src="@drawable/ic_dark_mode"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>
                <TextView
                    android:text="Chế độ tối"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <Switch
                    android:id="@+id/switchDark"
                    android:checked="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnLogout"
            android:text="Đăng xuất"
            android:textColor="#FF4444"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</ScrollView>