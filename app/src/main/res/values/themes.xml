<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MD_02_DATN" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:colorBackground">@color/background</item>
        <item name="colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnBackground">@color/onBackground</item>
        <item name="colorOnSurface">@color/onSurface</item>
        <item name="android:textColorPrimary">@color/onBackground</item>
        <item name="android:textColorSecondary">@color/onSurface</item>
        <item name="android:colorControlNormal">@color/onSurface</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
    </style>

    <style name="Theme.MD_02_DATN" parent="Base.Theme.MD_02_DATN" />

    <!-- Custom Alert Dialog Theme -->
    <style name="AlertDialogTheme" parent="Theme.Material3.Dark.Dialog">
        <item name="android:colorBackground">@color/surface</item>
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">#9CA3AF</item>
        <item name="buttonBarButtonStyle">@style/DialogButtonStyle</item>
    </style>

    <style name="DialogButtonStyle" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">#3B82F6</item>
    </style>

</resources>


